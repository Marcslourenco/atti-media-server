# ==========================================================
# ATTI Media Server - Variáveis de Ambiente (Exemplo)
# Copie para .env e ajuste conforme necessário.
# ==========================================================

# Ambiente
ATTI_ENV=local
ATTI_LOG_LEVEL=INFO

# Redis (broker/cache)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Persistência
ATTI_MODELS_DIR=/models
ATTI_LOG_DIR=/var/log/atti

# Rate limiting (SlowAPI)
# Ex.: "100/hour" ou "10/minute"
ATTI_RATE_LIMIT_PUBLIC=100/hour

# API Keys (separadas por vírgula). Use chaves longas e aleatórias.
# Ex.: ATTI_API_KEYS=key1,key2,key3
ATTI_API_KEYS=

# Cache de TTS
ATTI_TTS_CACHE_TTL_SECONDS=86400
# (Opcional) limite de tamanho para cachear áudio em bytes (padrão no código: 15MB)
ATTI_TTS_CACHE_MAX_BYTES=15728640

# Postgres opcional
# Habilite o profile with-postgres no compose e aponte aqui:
# DATABASE_URL=postgresql+psycopg2://atti:atti@postgres:5432/atti
DATABASE_URL=

# Celery
CELERY_CONCURRENCY=2
